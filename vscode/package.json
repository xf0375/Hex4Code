{
  "name": "hex4code-vscode",
  "displayName": "Hex4Code",
  "description": "AI-powered coding agent — multi-model routing, semantic cache, confidence tracking, pipeline orchestration",
  "version": "1.1.0",
  "license": "Apache-2.0",
  "publisher": "hex4code",
  "repository": {
    "type": "git",
    "url": "https://atomgit.com/zzwgbdt/Hex4Code"
  },
  "author": "Zhengzhou Weiguang Semiconductor Co., Ltd.",
  "engines": {
    "vscode": "^1.85.0",
    "node": ">=18.17.0"
  },
  "categories": [
    "Programming Languages",
    "Machine Learning",
    "Chat"
  ],
  "keywords": [
    "AI",
    "coding",
    "multi-model",
    "semantic-cache",
    "pipeline"
  ],
  "icon": "resources/icon.png",
  "activationEvents": [
    "*"
  ],
  "main": "./out/extension.js",
  "contributes": {
    "commands": [
      {
        "command": "hex4code.openView",
        "title": "Open Hex4Code",
        "icon": {
          "light": "resources/hex4_code_icon.svg",
          "dark": "resources/hex4_code_icon.svg"
        }
      },
      {
        "command": "hex4code.selectModel",
        "title": "Hex4Code: Select Model"
      },
      {
        "command": "hex4code.configureProviders",
        "title": "Hex4Code: Configure AI Providers"
      },
      {
        "command": "hex4code.configureTaskModels",
        "title": "Hex4Code: Configure Task-Specific Models"
      },
      {
        "command": "hex4code.toggleAgentMode",
        "title": "Hex4Code: Toggle Agent Mode"
      },
      {
        "command": "hex4code.providerHealth",
        "title": "Hex4Code: Provider Health Check"
      },
      {
        "command": "hex4code.showCostDashboard",
        "title": "Hex4Code: Show Cost Dashboard"
      },
      {
        "command": "hex4code.recommendModel",
        "title": "Hex4Code: Recommend Best Model"
      },
      {
        "command": "hex4code.voteOnSelection",
        "title": "Hex4Code: Multi-Model Vote on Selection"
      },
      {
        "command": "hex4code.showCacheStats",
        "title": "Hex4Code: Show Semantic Cache Stats"
      },
      {
        "command": "hex4code.benchmark",
        "title": "Hex4Code: Run Model Benchmark"
      },
      {
        "command": "hex4code.quotaStatus",
        "title": "Hex4Code: Show Quota Status"
      },
      {
        "command": "hex4code.showRouteInsights",
        "title": "Hex4Code: Show Route Insights"
      },
      {
        "command": "hex4code.configureModelsWebView",
        "title": "Hex4Code: Open Model Configuration Panel"
      }
    ],
    "configuration": {
      "title": "Hex4Code",
      "properties": {
        "hex4code.model": {
          "type": "string",
          "default": "deepseek-chat",
          "description": "Default AI model ID (e.g., deepseek-chat, gpt-4o, qwen-max)"
        },
        "hex4code.thinkingEnabled": {
          "type": "boolean",
          "default": false,
          "description": "Enable thinking/reasoning mode for supported models"
        },
        "hex4code.reasoningEffort": {
          "type": "string",
          "enum": [
            "high",
            "max"
          ],
          "default": "high",
          "description": "Reasoning effort level for thinking-enabled models"
        },
        "hex4code.debugLogEnabled": {
          "type": "boolean",
          "default": false,
          "description": "Enable debug logging to Output Channel"
        },
        "hex4code.webSearchTool": {
          "type": "string",
          "default": "",
          "description": "Web search tool command/URL (empty = disabled)"
        },
        "hex4code.notify": {
          "type": "string",
          "default": "",
          "description": "Notification preferences"
        }
      }
    },
    "viewsContainers": {
      "activitybar": [
        {
          "id": "hex4code",
          "title": "Hex4Code",
          "icon": "resources/panel-icon.svg"
        }
      ]
    },
    "views": {
      "hex4code": [
        {
          "id": "hex4code.chatView",
          "name": "Hex4Code",
          "icon": "resources/panel-icon.svg",
          "type": "webview"
        }
      ]
    },
    "menus": {
      "editor/title": [
        {
          "command": "hex4code.openView",
          "group": "navigation@100"
        }
      ]
    }
  },
  "scripts": {
    "typecheck": "tsc -p ./ --noEmit",
    "bundle": "esbuild ./src/extension.ts --bundle --platform=node --format=cjs --target=node18 --outfile=out/extension.js --external:vscode --external:*.node --sourcemap --footer:js=\"module.exports = { activate, deactivate };\" --log-override:empty-import-meta=silent",
    "compile": "npm run typecheck && npm run bundle",
    "build": "npm run compile",
    "test": "echo '⚠ No test files yet — see CONTRIBUTING.md for how to add tests'",
    "test:single": "tsx --test --test-timeout=60000",
    "watch": "tsc -w -p ./ --noEmit",
    "lint": "eslint src/",
    "lint:fix": "eslint src/ --fix",
    "format": "prettier --write 'src/**/*.{ts,tsx}'",
    "format:check": "prettier --check 'src/**/*.{ts,tsx}'",
    "test:coverage": "echo '⚠ No test files yet — run `npm test` first to add tests'"
    "vscode:prepublish": "npm run compile",
    "prepare": "husky"
  },
  "lint-staged": {
    "*.{ts,tsx}": [
      "prettier --write",
      "eslint --fix",
      "npx tsc -p ./ --noEmit"
    ],
    "*.{json,md,yaml,yml}": [
      "prettier --write"
    ]
  },
  "devDependencies": {
    "@eslint/js": "^9.39.4",
    "@types/ejs": "^3.1.5",
    "@types/markdown-it": "^14.1.1",
    "@types/node": "^20.12.7",
    "@types/vscode": "^1.85.0",
    "@vscode/vsce": "^3.9.1",
    "c8": "^10.1.3",
    "esbuild": "^0.25.12",
    "eslint": "^9.39.4",
    "gray-matter": "^4.0.3",
    "husky": "^9.1.7",
    "ignore": "^5.3.2",
    "lint-staged": "^17.0.4",
    "markdown-it": "^14.1.1",
    "openai": "^6.35.0",
    "prettier": "^3.8.3",
    "sharp": "^0.34.5",
    "tsx": "^4.21.0",
    "typescript": "^6.0.3",
    "typescript-eslint": "^8.59.2"
  },
  "dependencies": {
    "ejs": "^5.0.2",
    "openai": "^6.35.0",
    "zod": "^4.4.3"
  }
}
